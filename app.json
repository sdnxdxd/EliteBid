{
  "expo": {
    "name": "EliteBid",
    "slug": "elitebid",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "elitebid",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.elitebid.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "EliteBid usa tus fotos para cargar el frente y dorso del documento durante el registro."
      }
    },
    "android": {
      "package": "com.elitebid.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-sqlite"
    ]
  }
}
